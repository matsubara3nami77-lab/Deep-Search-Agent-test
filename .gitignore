# =============================================================================
# .gitignore — deepresearch-agent-test
# Stack: Python/FastAPI/LangGraph (backend) + Next.js/React/TypeScript (frontend)
# =============================================================================

# =============================================================================
# SECRETS & ENVIRONMENT VARIABLES
# =============================================================================
.env
.env.local
.env.*.local
.env.development
.env.production
.env.test
# Keep example/template env files
!.env.example
!.env.local.example
!*.env.example

# =============================================================================
# PYTHON — Backend
# =============================================================================
# Virtual environment
venv/
.venv/
env/
ENV/

# Byte-compiled / optimised files
__pycache__/
*.py[cod]
*$py.class
*.pyc
*.pyo

# Distribution / packaging
dist/
build/
*.egg-info/
*.egg
.eggs/
wheels/
*.whl

# Testing & coverage
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
nosetests.xml
coverage.xml
*.cover

# Type checking
.mypy_cache/
.dmypy.json
.pyre/
.pytype/

# Jupyter / IPython
.ipynb_checkpoints/
*.ipynb

# =============================================================================
# NODE / JAVASCRIPT — Frontend
# =============================================================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/

# =============================================================================
# NEXT.JS — Frontend build artifacts
# =============================================================================
.next/
out/
.vercel/
.turbo/

# TypeScript incremental build info
*.tsbuildinfo

# =============================================================================
# DATA — Generated reports and large files
# =============================================================================
data/reports/

# =============================================================================
# OS — macOS / Windows / Linux junk
# =============================================================================
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~

# =============================================================================
# IDE & EDITOR FILES
# =============================================================================
# Cursor AI
.cursor/

# VS Code — exclude user-specific settings but keep shared workspace config
.vscode/settings.json
.vscode/launch.json
.vscode/tasks.json
.vscode/*.code-snippets
.history/

# JetBrains (PyCharm, WebStorm, etc.)
.idea/
*.iml
*.iws
*.ipr

# Vim / Emacs
*.swp
*.swo
*.swn
*~
\#*\#
.#*

# =============================================================================
# LOGS & TEMPORARY FILES
# =============================================================================
logs/
*.log
*.pid
*.seed
*.pid.lock
tmp/
temp/
.tmp/

# =============================================================================
# MISCELLANEOUS
# =============================================================================
# Lock files — keep package-lock.json / yarn.lock for reproducibility
# but ignore pip lock if generated
pip-lock.txt

# Compiled binaries
*.so
*.dylib
*.dll
*.exe

# Archives
*.zip
*.tar.gz
*.tgz
*.rar
